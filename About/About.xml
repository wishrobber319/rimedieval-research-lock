<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ModMetaData>
    <packageId>wishRobber.rimedievalresearchlock</packageId>
    <name>Rimedieval - Enforced Research Lock</name>
    <author>wishRobber</author>
    <description>Actually enforce Rimedieval's tech-level limits. Rimedieval only hides too-advanced research, so mods like Research Whatever can still start it — this makes disallowed projects truly unstartable so nothing sneaks past your chosen tech level.</description>
    <supportedVersions>
        <li>1.6</li>
    </supportedVersions>
    <modDependencies>
        <li>
            <packageId>brrainz.harmony</packageId>
            <displayName>Harmony</displayName>
            <steamWorkshopUrl>steam://url/CommunityFilePage/2009463077</steamWorkshopUrl>
        </li>
        <li>
            <packageId>Ogam.Rimedieval</packageId>
            <displayName>Rimedieval</displayName>
            <steamWorkshopUrl>steam://url/CommunityFilePage/2516523040</steamWorkshopUrl>
        </li>
    </modDependencies>
    <loadAfter>
        <li>brrainz.harmony</li>
        <li>Ogam.Rimedieval</li>
        <li>avilmask.ResearchWhatever</li>
        <li>Mlie.ResearchTree</li>
    </loadAfter>
</ModMetaData>
